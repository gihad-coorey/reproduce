#NOTE: These vars are not injected automatically into the runtime environment. You must export them in your shell when running the SLURM script, or set them in the SLURM script itself. See scripts/eval_slurm.sh for an example of how to set these variables when submitting a job with sbatch.

# Note: If this is not set, the Libero module will attempt to find the config file at ~/.libero/config.yaml by default.
# The config file is used by the Libero module to determine where the Libero assets are located. 
# By default, they will be downloaded to your conda env, but you can set this variable to point to a config file that specifies a different location if you want. See configs/libero/config.yaml for an example config file.
# LIBERO_CONFIG_PATH=configs/libero/config.yaml

# Shared throughput controls (used by scripts/run_eval.py and scripts/eval_slurm.sh)
EPISODES_PER_TASK=10
N_ENVS=4

# SLURM wrapper defaults (used by scripts/eval_slurm.sh)
POLICY_NAME=HF
TASK_FILE=configs/tasks.json