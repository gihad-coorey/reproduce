# Note: If this is not set, the Libero module will attempt to find the config file at ~/.libero/config.yaml by default.
# The config file is used by the Libero module to determine where the Libero assets are located. 
# By default, they will be downloaded to your conda env, but you can set this variable to point to a config file that specifies a different location if you want. See configs/libero/config.yaml for an example config file.
# LIBERO_CONFIG_PATH=configs/libero/config.yaml

# Evaluation runtime paths (used by scripts/run_eval.py)
LIBERO_TASK_FILE=configs/tasks.json
# Optional: if unset, run_eval auto-groups under results/<policy>/<task_file_stem>/
LIBERO_RESULTS_PATH=
LIBERO_FRAMES_ROOT=results/headless_frame_dumps

# Throughput controls (used by scripts/run_eval.py)
LIBERO_EPISODES_PER_TASK=10
LIBERO_N_ENVS=4

# Optional PyTorch fallback behavior
PYTORCH_ENABLE_MPS_FALLBACK=1

# SLURM wrapper defaults (used by scripts/submit_eval_slurm*.sh)
CONDA_ENV_NAME=geng551x-gpu
POLICY_NAME=HF
TASK_FILE=configs/tasks_libero_90.json
EPISODES_PER_TASK=10
N_ENVS=4
